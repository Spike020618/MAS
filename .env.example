# RAG 系统配置文件 (.env)

# ════════════════════════════════════════════════════════════════════════════
# Milvus 配置
# ════════════════════════════════════════════════════════════════════════════

# Milvus 服务器地址
MILVUS_HOST=localhost

# Milvus 服务器端口 (gRPC)
MILVUS_PORT=19530

# Milvus 数据库名称
MILVUS_DB_NAME=rag_system

# Milvus 集合名称
MILVUS_COLLECTION_NAME=tasks

# ════════════════════════════════════════════════════════════════════════════
# DashScope 配置 (阿里云)
# ════════════════════════════════════════════════════════════════════════════

# DashScope API 密钥 (从阿里云获取)
DASHSCOPE_API_KEY=sk-f771855105fe43b28584a0f4d68fb5e9

# DashScope API 基础 URL
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope 模型名称
DASHSCOPE_MODEL=text-embedding-v4

# ════════════════════════════════════════════════════════════════════════════
# RAG 系统配置
# ════════════════════════════════════════════════════════════════════════════

# 向量数据库类型: "milvus" 或 "faiss"
VECTOR_DB_TYPE=milvus

# 嵌入模型类型: "dashscope" 或 "sentence-transformers"
EMBEDDING_MODEL_TYPE=dashscope

# 本地存储路径 (用于元数据备份)
STORAGE_PATH=./rag_storage_milvus

# ════════════════════════════════════════════════════════════════════════════
# 日志配置
# ════════════════════════════════════════════════════════════════════════════

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════════════════
# Docker 配置 (用于 docker-compose)
# ════════════════════════════════════════════════════════════════════════════

# Docker 卷存储目录
DOCKER_VOLUME_DIRECTORY=./volumes
